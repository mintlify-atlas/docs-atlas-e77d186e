  "keyFeatures": [
    "Market data for stocks, crypto, forex, futures, and indices",
    "Company profiles, financials, and earnings data",
    "SEC filings search and retrieval",
    "Insider ownership and transaction tracking",
    "FRED economic datasets and economic calendar",
    "Financial news and social/analyst sentiment analysis",
    "ESG scores and credit ratings",
    "Supply chain customer, supplier, and peer relationships",
    "ETF fund info, holdings, and exposure",
    "Web traffic data for companies"
  ],
  "publicApiSurface": [
